# ===== Server =====
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ===== API Security =====
MASTER_API_KEY=dev-master-key-123
API_RATE_LIMIT_WINDOW=900000
API_RATE_LIMIT_MAX=100

# ===== WhatsApp =====
WA_PHONE_NUMBER=6280000000000
WA_AUTH_DIR=./auth_state
WA_REPLY_ON_UNKNOWN=true
WA_RECONNECT_INTERVAL=5000
WA_MAX_RECONNECT_RETRIES=10

# ===== OTP Settings =====
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_CLEANUP_INTERVAL=300000

# ===== Database =====
DB_PATH=./data/otp.db

# ===== Webhook =====
WEBHOOK_TIMEOUT=10000
WEBHOOK_RETRY_COUNT=3
WEBHOOK_RETRY_DELAY=5000

# ===== Logging =====
LOG_LEVEL=info
LOG_DIR=./logs
